# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=suggestion_box
DB_USER=suggestion_box_user
DB_PASSWORD=secure_password_change_me

# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Session & Authentication
SESSION_SECRET=your_secret_key_here_change_in_production
SESSION_TIMEOUT=14400
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:8080,http://localhost

# Sentiment Analysis
SENTIMENT_API=textblob
TEXTBLOB_LANGUAGE=en

# Logging
LOG_LEVEL=debug

# Email (optional for future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
